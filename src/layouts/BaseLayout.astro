---
import '../styles/global.css';
import { assetUrl, siteName } from '../lib/seo';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonicalURL?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Theodore Meynard — Machine learning leader specializing in ranking, search, marketplace optimization, recommendations, experimentation, and MLOps.',
  keywords,
  canonicalURL = Astro.url.href,
  image = 'assets/profile/theodore-meynard.jpg',
  imageAlt = 'Photo of Theodore Meynard',
  ogType = 'website',
  jsonLd,
} = Astro.props;

// Normalize: strip trailing slash so we can always write `${base}/path`
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const normalizedCanonicalURL = canonicalURL.endsWith('/') ? canonicalURL : `${canonicalURL}/`;
const socialImage = image.startsWith('http') ? image : assetUrl(image);
const jsonLdGraph = jsonLd
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': Array.isArray(jsonLd) ? jsonLd : [jsonLd],
    }).replace(/<\/script/gi, '<\\/script')
  : undefined;

const navLinks = [
  { href: `${base}/`, label: 'About' },
  { href: `${base}/blog`, label: 'Blog' },
  { href: `${base}/talks`, label: 'Talks' },
  { href: `${base}/community`, label: 'Community' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} · {siteName}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={normalizedCanonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={normalizedCanonicalURL} />
    <meta property="og:title" content={`${title} · ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

    {jsonLdGraph && <script type="application/ld+json" set:html={jsonLdGraph} />}
  </head>
  <body>
    <header>
      <nav class="nav">
        <div class="nav-inner">
          <a class="nav-brand" href={`${base}/`}>TM</a>
          <ul class="nav-links">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class={currentPath.replace(/\/$/, '') === href.replace(/\/$/, '') || (href !== `${base}/` && currentPath.startsWith(href)) ? 'active' : ''}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} Theodore Meynard</span>
        <div class="footer-links">
          <a href="https://github.com/theopinard" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.linkedin.com/in/theodore-meynard" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
