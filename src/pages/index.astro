---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadYaml } from '../utils/loadData';

interface WorkEntry {
  company: string;
  role: string;
  period: string;
  description: string;
}

interface EducationEntry {
  institution: string;
  degree: string;
  year: number;
  note?: string;
}

interface SkillGroups {
  languages: string[];
  frameworks: string[];
  platforms: string[];
  practices: string[];
}

interface Profile {
  name: string;
  title: string;
  location: string;
  github: string;
  linkedin: string;
  keywords?: string;
  expertise_tags?: string[];
  bio: string;
  work: WorkEntry[];
  education: EducationEntry[];
  skills: SkillGroups;
}

const profile = loadYaml<Profile>('profile.yaml');
---

<BaseLayout
  title="About"
  description={`${profile.name} — ${profile.title} based in ${profile.location}.`}
  keywords={profile.keywords}
>
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-body">
        <div>
          <h1>{profile.name}</h1>
          <p class="subtitle">{profile.title} · {profile.location}</p>
          <p class="bio">{profile.bio}</p>
        </div>
        <img class="hero-photo" src="/about-me/MeynardTheodore.jpg" alt="Theodore Meynard" />
      </div>
      <div class="contact-strip">
        <a href={`https://github.com/${profile.github}`} target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          github.com/{profile.github}
        </a>
        <a href={`https://www.linkedin.com/in/${profile.linkedin}`} target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </section>

    <!-- Work History -->
    <section class="section">
      <h2>Experience</h2>
      <div class="timeline">
        {profile.work.map((job) => (
          <div class="timeline-item">
            <div class="timeline-period">{job.period}</div>
            <div class="timeline-content">
              <h3>{job.role}</h3>
              <p class="company">{job.company}</p>
              <p>{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="section">
      <h2>Education</h2>
      {profile.education.map((edu) => (
        <div class="edu-item">
          <div class="edu-year">{edu.year}</div>
          <div class="edu-content">
            <h3>{edu.degree}</h3>
            <p>{edu.institution}</p>
            {edu.note && <p>{edu.note}</p>}
          </div>
        </div>
      ))}
    </section>

    <!-- Skills -->
    <section class="section">
      <h2>Skills</h2>
      <div class="skills-grid">
        <div class="skill-group">
          <h3>Languages</h3>
          <ul>
            {profile.skills.languages.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div class="skill-group">
          <h3>Frameworks</h3>
          <ul>
            {profile.skills.frameworks.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div class="skill-group">
          <h3>Platforms</h3>
          <ul>
            {profile.skills.platforms.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div class="skill-group">
          <h3>Practices</h3>
          <ul>
            {profile.skills.practices.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
