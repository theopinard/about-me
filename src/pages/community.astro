---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { assetUrl as absoluteAssetUrl, breadcrumbJsonLd, personJsonLd, siteUrl } from '../lib/seo';

const community = await getEntry('site', 'community');

if (!community || community.data.kind !== 'community') {
  throw new Error('Missing site content: src/content/site/community.md');
}

const assetBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetUrl = (path: string) => `${assetBase}${path.replace(/^\/+/, '')}`;
const home = await getEntry('site', 'home');

if (!home || home.data.kind !== 'home') {
  throw new Error('Missing site content: src/content/site/home.md');
}

const pageUrl = siteUrl('/community');
const jsonLd = [
  personJsonLd(home.data),
  {
    '@type': 'AboutPage',
    '@id': `${pageUrl}#page`,
    url: pageUrl,
    name: community.data.title,
    description: community.data.description,
    image: absoluteAssetUrl(community.data.image),
    mainEntity: {
      '@id': `${siteUrl()}#theodore-meynard`,
    },
    about: [
      'PyData Berlin',
      'Data science community organization',
      'Machine learning community',
      'Conference organization',
      'Meetups',
    ],
    mentions: community.data.conferences.map((conf) => ({
      '@type': 'Thing',
      name: conf.name,
      url: conf.url,
      description: conf.role,
    })),
  },
  breadcrumbJsonLd([
    { name: 'About', url: siteUrl() },
    { name: 'Community', url: pageUrl },
  ]),
];
---

<BaseLayout
  title={community.data.title}
  description={community.data.description}
  canonicalURL={pageUrl}
  image={community.data.image}
  imageAlt={community.data.imageAlt}
  jsonLd={jsonLd}
>
  <div class="container">
    <div class="page-header">
      <h1>{community.data.title}</h1>
      {community.data.subtitle && <p>{community.data.subtitle}</p>}
    </div>

    <section class="community-overview" aria-label="Community involvement summary">
      {community.data.intro && <p>{community.data.intro}</p>}
      <img
        class="community-photo"
        src={assetUrl(community.data.image)}
        alt={community.data.imageAlt}
      />
      {community.data.metrics && (
        <div class="community-metrics">
          {community.data.metrics.map((metric) => (
            <div class="community-metric">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      )}
    </section>

    {community.data.sections && (
      <section class="community-detail-grid" aria-label="Community work areas">
        {community.data.sections.map((section) => (
          <div class="community-detail">
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </section>
    )}

    <section class="section community-events">
      <h2>{community.data.eventsTitle ?? 'Events'}</h2>
      <div class="conf-list">
        {community.data.conferences.map((conf) => (
          <div class="conf-item">
            <div class="conf-main">
              <a href={conf.url} target="_blank" rel="noopener noreferrer">
                {conf.name}
              </a>
              <span class="conf-role">{conf.role}</span>
            </div>
            {conf.logo && (
              <img class="conf-logo" src={assetUrl(conf.logo)} alt={conf.logoAlt ?? `${conf.name} logo`} loading="lazy" />
            )}
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
