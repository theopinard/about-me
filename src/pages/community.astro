---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { loadYaml } from '../utils/loadData';

interface Conference {
  name: string;
  url: string;
  role: string;
  logo?: string;
  logo_alt?: string;
}

const conferences = loadYaml<Conference[]>('conferences.yaml');
const community = await getEntry('pages', 'community');

if (!community) {
  throw new Error('Missing content page: src/content/pages/community.md');
}

---

<BaseLayout
  title={community.data.title}
  description={community.data.description}
>
  <div class="container">
    <div class="page-header">
      <h1>{community.data.title}</h1>
      {community.data.subtitle && <p>{community.data.subtitle}</p>}
    </div>

    <section class="community-overview" aria-label="Community involvement summary">
      {community.data.intro && <p>{community.data.intro}</p>}
      <img
        class="community-photo"
        src="/about-me/community_picture.jpeg"
        alt="PyData Berlin organizers on stage in front of the conference audience"
      />
      {community.data.metrics && (
        <div class="community-metrics">
          {community.data.metrics.map((metric) => (
            <div class="community-metric">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      )}
    </section>

    {community.data.sections && (
      <section class="community-detail-grid" aria-label="Community work areas">
        {community.data.sections.map((section) => (
          <div class="community-detail">
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </section>
    )}

    <section class="section community-events">
      <h2>{community.data.eventsTitle ?? 'Events'}</h2>
      <div class="conf-list">
        {conferences.map((conf) => (
          <div class="conf-item">
            <div class="conf-main">
              <a href={conf.url} target="_blank" rel="noopener noreferrer">
                {conf.name}
              </a>
              <span class="conf-role">{conf.role}</span>
            </div>
            {conf.logo && (
              <img class="conf-logo" src={conf.logo} alt={conf.logo_alt ?? `${conf.name} logo`} loading="lazy" />
            )}
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
