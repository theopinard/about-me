---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.year - a.data.year
);
---

<BaseLayout
  title="Talks"
  description="Conference talks and presentations by Theodore Meynard on machine learning and data science."
>
  <div class="container">
    <div class="page-header">
      <h1>Talks</h1>
      <p>Conference presentations.</p>
    </div>

    <div class="cards">
      {talks.map((talk) => (
        <article class="card talk-card" id={talk.id.replace(/(?:\.md)+$/, '')}>
          <div class="talk-card-body">
            <h3>{talk.data.title}</h3>
            <div class="meta">
              <span>{talk.data.event}</span>
              <span>{talk.data.year}</span>
            </div>
            {talk.data.description && <p>{talk.data.description}</p>}
            {(talk.data.video || talk.data.slides || talk.data.schedule || talk.data.repo) && (
              <div class="card-links">
                {talk.data.video && (
                  <a class="card-link" href={talk.data.video} target="_blank" rel="noopener noreferrer">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    Video
                  </a>
                )}
                {talk.data.slides && (
                  <a class="card-link" href={talk.data.slides} target="_blank" rel="noopener noreferrer">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8M12 17v4"/></svg>
                    Slides
                  </a>
                )}
                {talk.data.schedule && (
                  <a class="card-link" href={talk.data.schedule} target="_blank" rel="noopener noreferrer">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Schedule
                  </a>
                )}
                {talk.data.repo && (
                  <a class="card-link" href={talk.data.repo} target="_blank" rel="noopener noreferrer">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                    GitHub
                  </a>
                )}
              </div>
            )}
          </div>
          {talk.data.logo && (
            <img class="talk-logo" src={talk.data.logo} alt={talk.data.logoAlt ?? `${talk.data.event} logo`} loading="lazy" />
          )}
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
