---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbJsonLd, localPath, siteUrl } from '../lib/seo';

const blog = await getEntry('site', 'blog');

if (!blog || blog.data.kind !== 'blog') {
  throw new Error('Missing site content: src/content/site/blog.md');
}

const assetBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetUrl = (path: string) => `${assetBase}${path.replace(/^\/+/, '')}`;
const posts = [...blog.data.posts].sort((a, b) => b.date.valueOf() - a.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={blog.data.title}
  description={blog.data.description}
  canonicalURL={siteUrl('/blog')}
  jsonLd={[
    {
      '@type': 'CollectionPage',
      '@id': `${siteUrl('/blog')}#page`,
      name: blog.data.title,
      description: blog.data.description,
      url: siteUrl('/blog'),
      mainEntity: posts.map((post) => ({
        '@type': 'BlogPosting',
        headline: post.title,
        url: siteUrl(`/blog/${post.id}`),
        datePublished: post.date.toISOString().slice(0, 10),
        publisher: post.publisher,
      })),
    },
    breadcrumbJsonLd([
      { name: 'About', url: siteUrl() },
      { name: 'Blog', url: siteUrl('/blog') },
    ]),
  ]}
>
  <div class="container">
    <div class="page-header">
      <h1>{blog.data.title}</h1>
      <p>{blog.data.subtitle}</p>
    </div>

    <div class="cards">
      {posts.map((post) => (
        <article id={post.id} class="card blog-card">
          <div class="blog-card-body">
            <h3>
              <a href={localPath(`/blog/${post.id}`)}>
                {post.title}
              </a>
            </h3>
            <div class="meta">
              <span>{post.publisher}</span>
              <span>{formatDate(post.date)}</span>
            </div>
            <p>{post.summary}</p>
            {[...new Set([post.category, ...(post.tags ?? [])].filter(Boolean))].length > 0 && (
              <div class="tag-list compact-tag-list" aria-label={`Topics for ${post.title}`}>
                {[...new Set([post.category, ...(post.tags ?? [])].filter(Boolean))].map((tag) => <span>{tag}</span>)}
              </div>
            )}
            <div class="card-links">
              <a class="card-link" href={localPath(`/blog/${post.id}`)}>
                Details
              </a>
              <a class="card-link" href={post.url} target="_blank" rel="noopener noreferrer">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Original
              </a>
            </div>
          </div>
          {post.image && (
            <a class="blog-card-image-link" href={localPath(`/blog/${post.id}`)} aria-label={`Read details for ${post.title}`}>
              <img
                class="blog-card-image"
                src={assetUrl(post.image)}
                alt={post.imageAlt ?? ''}
                loading="lazy"
                style={post.imagePosition ? `object-position: ${post.imagePosition}` : undefined}
              />
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
